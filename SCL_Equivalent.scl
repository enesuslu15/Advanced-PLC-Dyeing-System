// ==============================================================================
// KUMAŞ BOYAMA MAKİNESİ - GÜNCEL SCL KODU (TP TIMER & EDGE TRIGGERS)
// ==============================================================================

// ----------------------------------------------------
// 1. REÇETE YÜKLEME (MOVE MANTIĞI)
// ----------------------------------------------------
IF "HMI_Load_Button" THEN
    "DB_Active_Process".Current_Recipe := "DB_Recipes".List["HMI_Recipe_Index"];
END_IF;

// ----------------------------------------------------
// 2. ANALOG SİNYAL İŞLEME VE ALARMLAR (SÜREKLİ ÇALIŞANLAR)
// ----------------------------------------------------
"Temp_Ratio_MD20" := NORM_X(MIN := 0, MAX := 27648, VALUE := "PT100_Raw_IW96");
"Current_Water_Temp_MD24" := SCALE_X(MIN := 0.0, MAX := 150.0, VALUE := "Temp_Ratio_MD20");

IF "Motor_Termik_Ariza" THEN
    "Alarm_Motor_Overload" := TRUE; // (S)
END_IF;

IF "HMI_Alarm_Reset_Button" THEN
    "Alarm_Motor_Overload" := FALSE; // (R)
END_IF;

// ----------------------------------------------------
// 3. STATE MACHINE (SIRALI İŞLEM)
// ----------------------------------------------------

// === ADIM 1: START VE SU ALMA (Güvenli Start) ===
IF "Start_Button" AND "Makine_Hazir_M0.0" THEN
    "Step_1_Su_Alma" := TRUE;       // (S)
    "Makine_Hazir_M0.0" := FALSE;   // (R) Başladıktan sonra hazır bitini düşür
END_IF;

"Su_Valfi_Q0.1" := "Step_1_Su_Alma"; 

IF "Step_1_Su_Alma" AND "Anlik_Litre" >= "Recete_Su_Hedef" THEN
    "Step_2_Isitma" := TRUE;  
    "Step_1_Su_Alma" := FALSE; 
END_IF;

// === ADIM 2: ISITMA VE KASKAD PID KONTROL ===
IF "Step_2_Isitma" THEN
    "Master_PID".Mode := 3; 
    "Slave_PID".Mode := 3;
END_IF;

// PID'yi Başlatmak için Yükselen Kenar (R_TRIG)
"PID_Start_Edge_Inst"(CLK := "Step_2_Isitma");
"Master_PID".ModeActivate := "PID_Start_Edge_Inst".Q;
"Slave_PID".ModeActivate := "PID_Start_Edge_Inst".Q;

IF "Step_2_Isitma" AND "Current_Water_Temp_MD24" >= "Target_Temp" THEN
    "Step_3_Dozajlama" := TRUE; 
    "Step_2_Isitma" := FALSE;  
END_IF;

// === ADIM 3: KİMYASAL DOZAJLAMA (TP TIMER İLE) ===
IF "Step_3_Dozajlama" THEN
    "Master_PID".Mode := 0; 
    "Slave_PID".Mode := 0;
END_IF;

// PID'yi Durdurmak için Yükselen Kenar (R_TRIG)
"PID_Stop_Edge_Inst"(CLK := "Step_3_Dozajlama");
"Master_PID".ModeActivate := "PID_Stop_Edge_Inst".Q;
"Slave_PID".ModeActivate := "PID_Stop_Edge_Inst".Q;

// TP Zamanlayıcısı: Sinyal gelince direkt başlar ve çıkış verir
"Dose_Timer_TP"(IN := "Step_3_Dozajlama", 
                PT := "Recipe_DoseA");

// Çıkışlar TP Timer'ın Q'suna direkt bağlıdır
"Dose_Pump_A" := "Dose_Timer_TP".Q;
"Dose_Pump_B" := "Dose_Timer_TP".Q;

// Sürenin bittiği anı yakalamak için Düşen Kenar (F_TRIG)
"Dose_Timer_F_Edge_Inst"(CLK := "Dose_Timer_TP".Q);

IF "Step_3_Dozajlama" AND "Dose_Timer_F_Edge_Inst".Q THEN
    "Step_4_Sogutma" := TRUE;  
    "Step_3_Dozajlama" := FALSE; 
END_IF;

// === ADIM 4: SOĞUTMA ===
"Soguk_Su_Valfi_Q0.2" := "Step_4_Sogutma"; 

IF "Step_4_Sogutma" AND "Current_Water_Temp_MD24" <= "Guvenli_Derece" THEN
    "Step_5_Tahliye" := TRUE;    
    "Step_4_Sogutma" := FALSE;   
END_IF;

// === ADIM 5: SUYU TAHLİYE ETME VE RESETLEME ===
"Tahliye_Valfi_Q0.3" := "Step_5_Tahliye"; 

IF "Step_5_Tahliye" AND "Anlik_Litre" <= "Bos_Siniri" THEN
    "Step_5_Tahliye" := FALSE;   
    "Makine_Hazir_M0.0" := TRUE; // Döngü bitti, makineyi tekrar hazırla
END_IF;
